<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#1C1C1E"
    android:orientation="vertical"
    android:padding="24dp">

    <!-- Header Spacer (Pushes content down) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="0.75" />

    <!-- Title Section -->
    <TextView
        android:id="@+id/tvOptionsTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fontFamily="sans-serif-black"
        android:gravity="center"
        android:text="SETTINGS"
        android:textColor="#FFFFFF"
        android:textSize="36sp"
        android:letterSpacing="0.1" />

    <View
        android:layout_width="match_parent"
        android:layout_height="100dp" />

    <!-- Volume Control Container (CardView for the rounded background) -->
    <androidx.cardview.widget.CardView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        app:cardBackgroundColor="#2C2C2E"
        app:cardCornerRadius="24dp"
        app:cardElevation="0dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="24dp">

            <!-- Label and Percentage Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:fontFamily="sans-serif-medium"
                    android:text="Music Volume"
                    android:textColor="#E5E5E7"
                    android:textSize="25sp" />

                <TextView
                    android:id="@+id/tvVolumePercentage"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:fontFamily="sans-serif-black"
                    android:text="100%"
                    android:textColor="#0A84FF"
                    android:textSize="25sp" />
            </LinearLayout>

            <!-- The Thicker Slider -->
            <SeekBar
                android:id="@+id/sbVolume"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="24dp"
                android:max="100"
                android:progress="100"
                android:minHeight="12dp"
                android:maxHeight="12dp"
                android:progressTint="#0A84FF"
                android:thumbTint="#FFFFFF"
                android:splitTrack="false"/>

        </LinearLayout>
    </androidx.cardview.widget.CardView>

    <!-- Info Text -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="16dp"
        android:gravity="center"
        android:text="Changes are applied immediately!"
        android:textColor="#8E8E93"
        android:textSize="15sp" />

    <!-- Bottom Spacer (Pushes button to the bottom) -->
    <View
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="2" />

    <!-- Back to Menu Button -->
    <Button
        android:id="@+id/btnBackToMenu"
        android:layout_width="match_parent"
        android:layout_height="64dp"
        android:backgroundTint="#2C2C2E"
        android:fontFamily="sans-serif-black"
        android:text="BACK TO MENU"
        android:textColor="#FFFFFF"
        android:textSize="16sp"
        app:cornerRadius="16dp"
        app:strokeColor="#3A3A3C"
        app:strokeWidth="1dp" />

</LinearLayout>